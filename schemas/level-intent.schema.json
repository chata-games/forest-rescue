{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://chata-games.dev/forest-rescue/level-intent.schema.json",
  "title": "LevelIntent",
  "type": "object",
  "required": ["schemaVersion", "id", "seed", "biome", "topology", "targets", "constraints", "waves"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": { "type": "string", "pattern": "^[0-9]{2}-[a-z0-9-]+$" },
    "seed": { "type": "string", "minLength": 1 },
    "biome": { "type": "string" },
    "name": { "type": "string" },
    "learningGoal": { "type": "string" },
    "topology": {
      "type": "object",
      "required": ["archetype", "entrances", "exits"],
      "properties": {
        "archetype": {
          "type": "string",
          "enum": [
            "single-s-curve",
            "two-path-merge",
            "fork-and-rejoin",
            "river-crossings",
            "switchbacks",
            "three-way-siege",
            "spiral-boss",
            "short-boss-assault",
            "elevated-paths"
          ]
        },
        "entrances": { "type": "integer", "minimum": 1 },
        "exits": { "type": "integer", "minimum": 1 }
      }
    },
    "targets": {
      "type": "object",
      "required": ["pathLength", "pathDensity", "ringCount", "difficulty", "durationMinutes"],
      "properties": {
        "pathLength": { "type": "number", "minimum": 400 },
        "pathDensity": { "type": "number", "minimum": 0, "maximum": 1 },
        "ringCount": { "type": "integer", "minimum": 3 },
        "difficulty": { "type": "number", "minimum": 0, "maximum": 1 },
        "durationMinutes": { "type": "number", "minimum": 1 }
      }
    },
    "constraints": {
      "type": "object",
      "properties": {
        "pathWidth": { "type": "number" },
        "minimumTurnRadius": { "type": "number" },
        "minimumParallelGap": { "type": "number" }
      }
    },
    "ringRoles": { "type": "array", "items": { "type": "string" } },
    "waves": {
      "type": "object",
      "required": ["count", "allowedEnemies", "budgetCurve"],
      "properties": {
        "count": { "type": "integer", "minimum": 1 },
        "allowedEnemies": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "budgetCurve": { "type": "string" }
      }
    },
    "landmarks": { "type": "array", "items": { "type": "string" } },
    "unlocks": { "type": "array", "items": { "type": "string" } },
    "levelModifiers": { "type": "array", "items": { "type": "string", "enum": ["tutorial-chopping", "river-crossings", "darkness"] } },
    "spellUnlock": { "type": ["string", "null"] },
    "bossId": { "type": ["string", "null"] },
    "waveOverrides": { "type": ["array", "null"] },
    "placementRules": {
      "type": "object",
      "properties": {
        "onPathDefenders": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
